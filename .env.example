# ============================================================
# Variables de entorno — landing-tedxbarriouniversitario
# Copiar a .env y completar. NUNCA commitear .env
# ============================================================

# URL del sitio en producción (sin trailing slash)
SITE_URL=https://tedxbarriouniversitario.cl

# Google Analytics 4 (PUBLIC_ = accesible en cliente)
# Crear en: analytics.google.com → Admin → Streams → Web → Measurement ID
PUBLIC_GA4_ID=G-XXXXXXXXXX

# Cloudflare Web Analytics (opcional, recomendado)
# Crear en: dash.cloudflare.com → Analytics → Web Analytics
PUBLIC_CF_ANALYTICS_TOKEN=

# Formspree — ID compartido para AMBOS formularios:
#   Formulario auspicio:  _tipo=partner           → alianzas@tedxbarriouniversitario.cl
#   Formulario speaker:   _tipo=postulacion-speaker → contacto@tedxbarriouniversitario.cl
# Crear en: formspree.io → New Form → copiar el ID del endpoint
# Ejemplo: si el endpoint es https://formspree.io/f/maqojvpw → ID es maqojvpw
# ⚠️ Correos pendientes de provisionar en DirectAdmin (contacto@ y alianzas@)
FORMSPREE_FORM_ID=xxxxxxxx

# BASE_PATH — para preview en subdirectorio (ej: GitHub Pages)
# En producción (tedxbarriouniversitario.cl): dejar vacío
# En GitHub Pages (/landing-tedxbarriouniversitario): /landing-tedxbarriouniversitario
BASE_PATH=
