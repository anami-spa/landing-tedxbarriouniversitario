/*
  # ============================================================
  # HEADERS DE SEGURIDAD — Cloudflare Pages
  # Proyecto: landing-tedxbarriouniversitario
  # Aplican a todas las rutas del sitio.
  #
  # NOTA SRI: GA4 y CF Analytics no publican hashes estables
  # → no se puede usar SRI en esos scripts.
  # Control compensatorio: CSP restringe dominios permitidos.
  # ============================================================

  # Clickjacking
  X-Frame-Options: DENY

  # MIME sniffing
  X-Content-Type-Options: nosniff

  # Referrer
  Referrer-Policy: strict-origin-when-cross-origin

  # Permisos de APIs de browser
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()

  # HSTS — activar solo cuando el sitio esté 100% en HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy (TEDx landing)
  # Fuentes: todas locales (@fontsource/* en public/) → font-src 'self' suficiente
  # Imágenes: solo 'self' + data: (no hay imágenes de CDN externo)
  # Formularios: Formspree (https://formspree.io)
  # Analytics: GA4 (googletagmanager.com) + CF Analytics (cloudflareinsights.com)
  # 'unsafe-inline' en script-src: requerido por gtag inline. Sin nonce porque es estático.
  # 'unsafe-inline' en style-src: requerido por Tailwind 4 / Astro inlineStylesheets.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://formspree.io https://www.google-analytics.com https://analytics.google.com https://cloudflareinsights.com; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests

  # XSS legacy
  X-XSS-Protection: 1; mode=block
