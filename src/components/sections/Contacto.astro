---
/**
 * Contacto.astro — Formulario de contacto con Formspree (modo estático)
 *
 * Incluye:
 * - Honeypot anti-spam (_gotcha oculto)
 * - Redirect a /gracias tras envío exitoso
 * - Labels explícitos en todos los campos (WCAG 1.3.1)
 * - Estados de error gestionados por Formspree
 *
 * IMPORTANTE: FORMSPREE_FORM_ID debe estar en .env (nunca hardcodeado aquí).
 * Si se necesita un endpoint SSR propio, ver Stack_y_Mejoras_Tecnicas.md
 */
export interface Props {
  title?: string
  subtitle?: string
  siteUrl: string
  formspreeId: string
}

const {
  title = '¿Listo para empezar?',
  subtitle = 'Escríbenos y te respondemos en menos de 24 horas.',
  siteUrl,
  formspreeId,
} = Astro.props
---

<section class="bg-white py-16 md:py-24" id="contacto">
  <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
        {title}
      </h2>
      <p class="mt-4 text-lg text-neutral-600">{subtitle}</p>
    </div>

    <form
      class="mt-12 space-y-6"
      action={`https://formspree.io/f/${formspreeId}`}
      method="POST"
      novalidate
    >
      <!-- Honeypot anti-spam: oculto visualmente y para AT, no debe ser llenado por humanos -->
      <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
        <label for="_gotcha">No completar este campo</label>
        <input
          id="_gotcha"
          type="text"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
        />
      </div>

      <!-- Redirect a /gracias tras envío exitoso -->
      <input type="hidden" name="_next" value={`${siteUrl}/gracias`} />

      <div>
        <label for="nombre" class="block text-sm font-semibold text-neutral-900">
          Nombre completo <span aria-hidden="true">*</span>
          <span class="sr-only">(requerido)</span>
        </label>
        <input
          id="nombre"
          name="nombre"
          type="text"
          autocomplete="name"
          required
          class="mt-2 block w-full rounded-lg border border-neutral-300 px-4 py-3 text-neutral-900 placeholder-neutral-400 shadow-sm transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary sm:text-sm"
          placeholder="María González"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-neutral-900">
          Correo electrónico <span aria-hidden="true">*</span>
          <span class="sr-only">(requerido)</span>
        </label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="mt-2 block w-full rounded-lg border border-neutral-300 px-4 py-3 text-neutral-900 placeholder-neutral-400 shadow-sm transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary sm:text-sm"
          placeholder="maria@empresa.cl"
        />
      </div>

      <div>
        <label for="empresa" class="block text-sm font-semibold text-neutral-900">
          Empresa
        </label>
        <input
          id="empresa"
          name="empresa"
          type="text"
          autocomplete="organization"
          class="mt-2 block w-full rounded-lg border border-neutral-300 px-4 py-3 text-neutral-900 placeholder-neutral-400 shadow-sm transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary sm:text-sm"
          placeholder="Mi Empresa SpA"
        />
      </div>

      <div>
        <label for="mensaje" class="block text-sm font-semibold text-neutral-900">
          Mensaje <span aria-hidden="true">*</span>
          <span class="sr-only">(requerido)</span>
        </label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          required
          class="mt-2 block w-full rounded-lg border border-neutral-300 px-4 py-3 text-neutral-900 placeholder-neutral-400 shadow-sm transition focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary sm:text-sm"
          placeholder="Cuéntanos sobre tu proyecto..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full rounded-lg bg-primary px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors hover:bg-primary-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Enviar mensaje
      </button>

      <p class="text-center text-xs text-neutral-500">
        Al enviar aceptas nuestra política de privacidad.
        Respondemos en menos de 24 horas hábiles.
      </p>
    </form>
  </div>
</section>
