---
/**
 * FAQ.astro — Sección de preguntas frecuentes
 * Usa <details>/<summary> nativos (sin JS), más FAQPage JSON-LD automático.
 * Los datos se pasan desde BaseLayout.astro → SEO.astro para el schema.
 */
export interface Props {
  faqs: Array<{
    question: string
    answer: string
  }>
  title?: string
}

const { faqs, title = 'Preguntas frecuentes' } = Astro.props
---

<section class="bg-neutral-50 py-16 md:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl">
      {title}
    </h2>
    <dl class="mt-12 space-y-4">
      {faqs.map((faq, i) => (
        <details
          class="group rounded-xl border border-neutral-200 bg-white shadow-sm"
          id={`faq-${i}`}
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left font-semibold text-neutral-900 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            <span class="text-base">{faq.question}</span>
            <!-- Ícono chevron, rotado cuando está abierto -->
            <span
              class="flex-shrink-0 text-neutral-400 transition-transform group-open:rotate-180"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 7.5L10 12.5L15 7.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <dd class="px-6 pb-5 text-neutral-600 leading-7">
            {faq.answer}
          </dd>
        </details>
      ))}
    </dl>
  </div>
</section>
