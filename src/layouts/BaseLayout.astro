---
import SEO from '../components/SEO.astro'
import '../styles/global.css'

export interface Props {
  title: string
  description: string
  ogImage?: string
  event?: Parameters<typeof SEO>[0]['event']
}

const { title, description, ogImage, event } = Astro.props

const ga4Id = import.meta.env.PUBLIC_GA4_ID
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<!doctype html>
<html lang="es">
  <head>
    <SEO
      title={title}
      description={description}
      canonicalURL={new URL(Astro.url.pathname, Astro.site)}
      ogImage={ogImage}
      event={event}
    />

    <!-- Google Analytics 4 -->
    {ga4Id && ga4Id !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
        <script define:vars={{ ga4Id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga4Id, { anonymize_ip: true, cookie_flags: 'SameSite=None;Secure' });
        </script>
      </>
    )}

    <!-- Cloudflare Web Analytics -->
    {cfAnalyticsToken && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`} />
    )}
  </head>

  <body>
    <a href="#contenido-principal" class="skip-link">Saltar al contenido principal</a>

    <!-- ============================================================
         HEADER — claro sticky con logo TEDx negro
         ============================================================ -->
    <header class="site-header" role="banner">
      <div class="site-header__inner">
        <a href="#inicio" class="site-header__logo-link" aria-label="TEDxBarrioUniversitario Women — ir al inicio">
          <img
            src={`${baseUrl}/logo-tedx-negro.svg`}
            alt="TEDxBarrioUniversitario Women"
            width="160"
            height="50"
            loading="eager"
            decoding="async"
            class="site-header__logo"
          />
        </a>

        <nav aria-label="Navegación principal" class="site-header__nav">
          <a href="#que-es-tedx"   class="header-nav-link header-nav-wide">¿Qué es?</a>
          <a href="#evento"        class="header-nav-link header-nav-wide">El evento</a>
          <a href="#auspiciadores" class="header-nav-link">Auspicios</a>
          <a href="#equipo"        class="header-nav-link header-nav-wide">Equipo</a>
          <a href="#speakers"      class="header-nav-link btn-primary"
             aria-label="Postular como speaker al evento TEDx">
            Postular →
          </a>
        </nav>
      </div>
    </header>

    <!-- WCAG 2.4.1: tabindex="-1" permite que el skip-link mueva el foco — FINDING-04 -->
    <main id="contenido-principal" tabindex="-1">
      <slot />
    </main>

    <!-- ============================================================
         FOOTER — oscuro con logo TEDx blanco
         ============================================================ -->
    <footer class="site-footer dark-section" role="contentinfo">
      <div class="site-footer__inner">
        <div class="site-footer__top">

          <!-- Marca -->
          <div class="site-footer__brand">
            <img
              src={`${baseUrl}/logo-tedx-blanco.svg`}
              alt="TEDxBarrioUniversitario Women"
              width="160"
              height="50"
              loading="lazy"
              decoding="async"
              class="site-footer__logo"
            />
            <p class="site-footer__tagline">
              Ideas que conectan, voces que transforman.
            </p>
            <div class="site-footer__social" role="list" aria-label="Redes sociales">
              <!-- FINDING-21: visible text "IG" ocultado a AT → aria-label contiene el nombre completo -->
              <a href="https://www.instagram.com/tedxbarriouniversitario"
                 rel="noopener noreferrer" target="_blank"
                 class="site-footer__social-link" role="listitem"
                 aria-label="Instagram de TEDxBarrioUniversitario (abre en nueva pestaña)">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <span aria-hidden="true">IG</span>
              </a>
              <a href="https://www.linkedin.com/company/tedxbarriouniversitario"
                 rel="noopener noreferrer" target="_blank"
                 class="site-footer__social-link" role="listitem"
                 aria-label="LinkedIn de TEDxBarrioUniversitario (abre en nueva pestaña)">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span aria-hidden="true">LinkedIn</span>
              </a>
            </div>
          </div>

          <!-- Evento -->
          <div>
            <h3 class="site-footer__heading">El evento</h3>
            <ul class="site-footer__list">
              <li>04 Diciembre 2026</li>
              <li>09:00 — 13:00 hrs</li>
              <li>Universidad de Concepción</li>
              <li>Concepción, Chile</li>
            </ul>
          </div>

          <!-- Links -->
          <div>
            <h3 class="site-footer__heading">Participar</h3>
            <ul class="site-footer__list">
              <li><a href="#auspiciadores" class="site-footer__link">Ser auspiciador</a></li>
              <li><a href="#speakers" class="site-footer__link">Postular como speaker</a></li>
              <li>
                <a href="https://www.ted.com/tedx/events/69535"
                   target="_blank" rel="noopener noreferrer"
                   class="site-footer__link"
                   aria-label="Evento oficial en TED.com (abre en nueva pestaña)">
                  ted.com/tedx ↗
                </a>
              </li>
            </ul>
          </div>

          <!-- UdeC -->
          <div>
            <h3 class="site-footer__heading">Sede</h3>
            <div class="site-footer__udec">
              <!-- Escudo UdeC en SVG simple o texto -->
              <p class="text-sm text-white/60 leading-relaxed">
                Universidad de Concepción<br/>
                Concepción, Biobío, Chile
              </p>
            </div>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="site-footer__bottom">
          <span>© {new Date().getFullYear()} TEDxBarrioUniversitario Women · Concepción, Chile</span>
          <span class="text-white/40 text-xs">
            Organizado de forma independiente bajo licencia TED. Las opiniones expresadas son exclusivas de sus organizadores y no representan a TED Conferences LLC.
          </span>
        </div>
      </div>
    </footer>

  </body>
</html>

<style>
/* ============================================================
   HEADER — claro sticky
   ============================================================ */
.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: #f7f7f7;
  border-bottom: 1px solid rgba(35,35,35,0.12);
}

.site-header__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 10px clamp(16px, 4vw, 32px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.site-header__logo-link {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}

.site-header__logo {
  height: 38px;
  width: auto;
  display: block;
}

.site-header__nav {
  display: flex;
  align-items: center;
  gap: clamp(12px, 2vw, 20px);
}

.header-nav-link {
  font-family: var(--font-display);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-charcoal);
  text-decoration: none;
  padding: 10px 4px;
  white-space: nowrap;
  transition: color 0.15s ease;
}

.header-nav-link:hover { color: var(--color-ted-red); }

.header-nav-link:focus-visible {
  outline: 2px solid var(--color-charcoal);
  outline-offset: 3px;
  border-radius: 2px;
}

/* En móvil < 640px: ocultar nav wide, mostrar solo CTA */
@media (max-width: 639px) {
  .header-nav-wide { display: none !important; }
  .site-header__logo { height: 30px; }
}

/* En tablet 640-900: ocultar algunos nav */
@media (max-width: 900px) {
  .header-nav-wide { display: none; }
}

/* ============================================================
   FOOTER — dark charcoal
   ============================================================ */
.site-footer {
  background: var(--color-charcoal);
  color: #fff;
  border-top: 3px solid var(--color-ted-red);
}

.site-footer__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: clamp(44px, 6vw, 72px) clamp(16px, 5vw, 32px) 28px;
}

.site-footer__top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: clamp(24px, 4vw, 48px);
}

@media (max-width: 768px) {
  .site-footer__top {
    grid-template-columns: 1fr 1fr;
    gap: 28px 20px;
  }
  .site-footer__brand { grid-column: 1 / -1; }
}

@media (max-width: 480px) {
  .site-footer__top { grid-template-columns: 1fr; }
}

.site-footer__logo {
  height: 36px;
  width: auto;
  display: block;
  margin-bottom: 14px;
  /* Asegurar que el SVG sea blanco sobre dark */
  filter: brightness(0) invert(1);
}

.site-footer__tagline {
  font-size: 14px;
  line-height: 1.6;
  color: rgba(255,255,255,0.55);
  max-width: 28ch;
  margin: 0 0 16px;
}

.site-footer__social {
  display: flex;
  gap: 10px;
}

.site-footer__social-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  color: rgba(255,255,255,0.55);
  font-size: 0.75rem;
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: 0.06em;
  text-decoration: none;
  text-transform: uppercase;
  padding: 5px 10px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 4px;
  transition: color 0.15s, border-color 0.15s;
}
.site-footer__social-link:hover {
  color: #fff;
  border-color: rgba(255,255,255,0.4);
}
.site-footer__social-link:focus-visible {
  outline: 2px solid #fff;
  outline-offset: 2px;
}

.site-footer__heading {
  font-family: var(--font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin: 0 0 14px;
}

.site-footer__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 0.875rem;
  color: rgba(255,255,255,0.65);
  font-family: var(--font-sans);
}

.site-footer__link {
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  transition: color 0.15s;
}
.site-footer__link:hover { color: #fff; }
.site-footer__link:focus-visible {
  outline: 2px solid #fff;
  outline-offset: 2px;
  border-radius: 2px;
}

.site-footer__bottom {
  margin-top: clamp(32px, 4vw, 52px);
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: space-between;
  align-items: flex-start;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.65); /* era 0.4 → 2.4:1 FALLA → 0.65 = 4.6:1 ✓ WCAG AA */
  font-family: var(--font-sans);
}
</style>
