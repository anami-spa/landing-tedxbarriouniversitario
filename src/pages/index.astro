</style>


<!-- ============================================================
     JAVASCRIPT — Countdown, CountUp, Carrusel, Parallax
     Todo bajo prefers-reduced-motion
     ============================================================ -->
<script>
(function (): void {
  'use strict'

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  /* ── COUNTDOWN ───────────────────────────────────────────── */
  const TARGET = new Date('2026-12-04T09:00:00-03:00').getTime()
  const cdDias  = document.getElementById('cd-dias')
  const cdHoras = document.getElementById('cd-horas')
  const cdMin   = document.getElementById('cd-min')
  const cdSeg   = document.getElementById('cd-seg')

  function pad(n: number): string { return String(n).padStart(2, '0') }

  function tickCountdown(): void {
    const diff = TARGET - Date.now()
    if (diff <= 0) {
      if (cdDias)  cdDias.textContent  = '00'
      if (cdHoras) cdHoras.textContent = '00'
      if (cdMin)   cdMin.textContent   = '00'
      if (cdSeg)   cdSeg.textContent   = '00'
      return
    }
    const days  = Math.floor(diff / 86400000)
    const hours = Math.floor((diff % 86400000) / 3600000)
    const mins  = Math.floor((diff % 3600000)  / 60000)
    const secs  = Math.floor((diff % 60000)    / 1000)
    if (cdDias)  cdDias.textContent  = String(days)
    if (cdHoras) cdHoras.textContent = pad(hours)
    if (cdMin)   cdMin.textContent   = pad(mins)
    if (cdSeg)   cdSeg.textContent   = pad(secs)
  }

  if (prefersReduced) {
    const remaining = Math.max(0, TARGET - Date.now())
    const days = Math.floor(remaining / 86400000)
    if (cdDias)  cdDias.textContent  = String(days)
    if (cdHoras) cdHoras.textContent = '--'
    if (cdMin)   cdMin.textContent   = '--'
    if (cdSeg)   cdSeg.textContent   = '--'
  } else {
    tickCountdown()
    setInterval(tickCountdown, 1000)
  }

  /* ── COUNT-UP COUNTERS ───────────────────────────────────── */
  const counterEls = document.querySelectorAll<HTMLElement>('.js-counter')

  const allCounters = Array.from(counterEls).map(el => ({
    el,
    target: parseInt(el.dataset.target ?? '0', 10),
    pad:    parseInt(el.dataset.pad    ?? '0', 10),
  }))

  const fmt = (n: number, pad: number) =>
    pad > 0 ? String(n).padStart(pad, '0') : String(n)

  if (prefersReduced) {
    allCounters.forEach(({ el, target, pad }) => { el.textContent = fmt(target, pad) })
  } else {
    const runCounter = (el: HTMLElement, target: number, pad: number): void => {
      const duration = 1200
      const step = 16
      const inc = Math.ceil(target / (duration / step))
      let current = 0
      const timer = setInterval(() => {
        current = Math.min(current + inc, target)
        el.textContent = fmt(current, pad)
        if (current >= target) clearInterval(timer)
      }, step)
    }

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return
        const item = allCounters.find(c => c.el === entry.target)
        if (item) {
          runCounter(item.el, item.target, item.pad)
          obs.unobserve(item.el)
        }
      })
    }, { threshold: 0.5 })

    allCounters.forEach(({ el, pad }) => {
      el.textContent = fmt(0, pad)
      obs.observe(el)
    })
  }

  /* ── PARTNERS CAROUSEL ───────────────────────────────────── */
  const track      = document.getElementById('partners-track')
  const dotsEl     = document.getElementById('partners-dots')
  const btnPrev    = document.getElementById('btn-prev')
  const btnNext    = document.getElementById('btn-next')
  const announceEl = document.getElementById('carousel-announce')

  if (track && dotsEl && btnPrev && btnNext) {
    let current = 0
    const slides   = track.children.length
    const slideEls = Array.from(track.children)
    const dots     = dotsEl.querySelectorAll('.partners-dot')
    let announceTimer: ReturnType<typeof setTimeout> | null = null

    const getVisible = (): number => {
      if (window.innerWidth >= 1024) return slides  // todos a la vez → sin nav
      if (window.innerWidth >= 640)  return 3
      return 1
    }

    const updateControls = (): void => {
      const visible = getVisible()
      const allVisible = visible >= slides
      ;(btnPrev as HTMLElement).style.display = allVisible ? 'none' : ''
      ;(btnNext as HTMLElement).style.display = allVisible ? 'none' : ''
      dotsEl.style.display = allVisible ? 'none' : ''
      if (allVisible) {
        track.style.transform = 'translateX(0)'
        current = 0
      }
    }

    const goTo = (idx: number): void => {
      const visible = getVisible()
      if (visible >= slides) return         // todos visibles, sin scroll
      const maxPos = slides - visible
      current = Math.max(0, Math.min((idx + slides) % slides, maxPos))
      track.style.transform = `translateX(-${current * (100 / slides)}%)`
      dots.forEach((d, i) => {
        d.classList.toggle('partners-dot--active', i === current)
        d.setAttribute('aria-pressed', i === current ? 'true' : 'false')
      })
      if (announceEl) {
        const visNames = slideEls.slice(current, current + visible)
          .map(s => s.getAttribute('aria-label') ?? '').filter(Boolean).join(', ')
        if (announceTimer !== null) clearTimeout(announceTimer)
        announceEl.textContent = `Mostrando: ${visNames}`
        announceTimer = setTimeout(() => { announceEl.textContent = '' }, 2000)
      }
    }

    btnPrev.addEventListener('click', () => goTo(current - 1))
    btnNext.addEventListener('click', () => goTo(current + 1))
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)))
    window.addEventListener('resize', updateControls, { passive: true })
    updateControls()
  }

  /* ── PARALLAX (fotos grandes) ────────────────────────────── */
  if (!prefersReduced && window.innerWidth > 768) {
    const parallaxItems = document.querySelectorAll<HTMLElement>('.parallax-img img')
    if (parallaxItems.length) {
      let ticking = false
      const onScroll = (): void => {
        if (!ticking) {
          requestAnimationFrame(() => {
            parallaxItems.forEach(img => {
              const wrap = img.closest('.parallax-img')
              if (!wrap) return
              const rect    = wrap.getBoundingClientRect()
              const centerY = rect.top + rect.height / 2
              const offset  = (window.innerHeight / 2 - centerY) * 0.08
              img.style.transform = `translateY(${offset}px)`
            })
            ticking = false
          })
          ticking = true
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true })
    }
  }

  /* ── SCROLL REVEALS ──────────────────────────────────────── */
  if (!prefersReduced) {
    const revealEls = document.querySelectorAll<HTMLElement>(
      '.equipo-card, .beneficio-card, .s-proceso__step, .s-auspi__bullet'
    )
    if (revealEls.length) {
      const revObs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement
            el.style.opacity   = '1'
            el.style.transform = 'translateY(0)'
            revObs.unobserve(entry.target)
          }
        })
      }, { threshold: 0.15 })

      revealEls.forEach((el, i) => {
        el.style.opacity    = '0'
        el.style.transform  = 'translateY(24px)'
        el.style.transition = `opacity 0.45s ease ${i * 0.05}s, transform 0.45s ease ${i * 0.05}s`
        revObs.observe(el)
      })
    }
  }

})()
</script>

</BaseLayout>
