---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'

// Imágenes procesadas por astro:assets (WebP, srcset automático)
import imgHero       from '../assets/images/hero-01.webp'
import imgEquipoJav  from '../assets/images/equipo-javiera.webp'
import imgEquipoPau  from '../assets/images/equipo-paula.webp'
import imgEquipoPam  from '../assets/images/equipo-pamela.webp'
import imgEquipoGab  from '../assets/images/equipo-gabriela.webp'
import imgEquipoNat  from '../assets/images/equipo-natalie.webp'
import imgEquipoCla  from '../assets/images/equipo-claudio.webp'
import imgFotoSec02  from '../assets/images/foto-seccion-02.webp'
import imgFicha      from '../assets/images/ficha-tecnica.webp'
import imgAuspPolar  from '../assets/images/auspiciador-polaroid.webp'
import imgConvoca    from '../assets/images/convocatoria-speakers.webp'
import imgContacto   from '../assets/images/contacto-01.webp'

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '')

// ============================================================
// CONTENIDO — fuente de verdad. Editar aquí, nunca inventar datos.
// ============================================================

const evento = {
  nombre:        'TEDxBarrioUniversitario Women 2026',
  tema:          'Alzar el vuelo',
  fecha:         '04 de Diciembre, 2026',
  horario:       '09:00 — 13:00',
  lugar:         'Universidad de Concepción',
  auditorio:     'Auditorio [por confirmar]',
  ciudad:        'Concepción, Chile',
  speakers:      8,
  asistentes:    100,
  ideas:         1,
  url:           'https://www.ted.com/tedx/events/69535',
  email:         'contacto@tedxbarriouniversitario.cl',
  emailAlianzas: 'alianzas@tedxbarriouniversitario.cl',
  ig:            '@tedxbarriouniversitario',
  linkedin:      'tedxbarriouniversitario',
  flickr:        'tedxbarriouniversitario',
  countdown:     '2026-12-04T09:00:00-03:00',
}

const equipo = [
  { nombre: 'Javiera Burgos',  cargo: 'Organizadora y Directora General',          img: imgEquipoJav, slug: 'javiera'  },
  { nombre: 'Paula Cifuentes', cargo: 'Coorganizadora y Directora de Comunicaciones', img: imgEquipoPau, slug: 'paula' },
  { nombre: 'Pamela Pérez',    cargo: 'Curaduría y Speaker Coach',                 img: imgEquipoPam, slug: 'pamela'  },
  { nombre: 'Claudio Muñoz',   cargo: 'Coach y Consultor del Equipo Organizador',  img: imgEquipoCla, slug: 'claudio' },
  { nombre: 'Gabriela Concha', cargo: 'Producción y Logística',                    img: imgEquipoGab, slug: 'gabriela'},
  { nombre: 'Natalie Aguayo',  cargo: 'Directora Creativa',                        img: imgEquipoNat, slug: 'natalie' },
]

const tematicas = [
  'Liderazgo femenino',
  'Ciencia, tecnología y futuro (STEM)',
  'Innovación y emprendimiento',
  'Bienestar y calidad de vida',
  'Equidad de género',
  'Impacto social y sostenibilidad',
]

const beneficios = [
  {
    icono: '📍',
    titulo: 'Posicionamiento',
    texto: 'Vincula tu marca al ecosistema TED, reconocido globalmente por el impacto de sus ideas.',
  },
  {
    icono: '🌿',
    titulo: 'Marca con propósito',
    texto: 'Asocia tu organización a valores de innovación, equidad y transformación social.',
  },
  {
    icono: '👁️',
    titulo: 'Visibilidad estratégica',
    texto: 'Presencia ante líderes, académicos, emprendedores y la comunidad universitaria del Biobío.',
  },
  {
    icono: '🤝',
    titulo: 'Networking de alto valor',
    texto: 'Conecta con una audiencia selecta de personas movilizadas por ideas y propósito.',
  },
]

const procesoSpeaker = [
  { num: '01', titulo: 'Postulación formulario',              desc: 'Completa el formulario con tu idea y perfil.' },
  { num: '02', titulo: 'Video presentación',                  desc: 'Envía un video breve presentando tu idea.' },
  { num: '03', titulo: 'Entrevista con el equipo curatorial', desc: 'El equipo editorial evalúa y selecciona.' },
]

const partners = [
  { categoria: 'Institución Anfitriona', logos: ['udec'], placeholder: false },
  { categoria: 'Main',        logos: [], placeholder: true },
  { categoria: 'Estratégico', logos: ['anami'], placeholder: false },
  { categoria: 'Experiencia', logos: [], placeholder: true },
  { categoria: 'Media',       logos: [], placeholder: true },
]

const seoEvent = {
  name:        'TEDxBarrioUniversitario Women 2026 — Alzar el vuelo',
  description: 'Evento TEDx independiente en la Universidad de Concepción. 8 charlas en vivo sobre ideas que transforman. 4 de diciembre de 2026.',
  startDate:   '2026-12-04T09:00:00-03:00',
  endDate:     '2026-12-04T13:00:00-03:00',
  url:         'https://tedxbarriouniversitario.cl',
  location: {
    name:    'Universidad de Concepción',
    address: 'Campus UdeC',
    city:    'Concepción',
    country: 'CL',
  },
  organizer: 'TEDxBarrioUniversitario Women',
}

const FORMSPREE_ID = import.meta.env.FORMSPREE_FORM_ID ?? 'xxxxxxxx'
---

<BaseLayout
  title="TEDxBarrioUniversitario Women 2026 · Alzar el vuelo"
  description="8 charlas que inspiran. 4 de diciembre de 2026 · Universidad de Concepción · Ideas que conectan, voces que transforman."
  ogImage="/og-tedx.jpg"
  event={seoEvent}
>

<!-- ============================================================
     S1 — HERO OSCURO "Alzar el vuelo"
     Foto full-bleed fondo. Texto vertical izquierda. Countdown inferior.
     ============================================================ -->
<section id="inicio" class="s-hero dark-section" aria-label="Inicio — Alzar el vuelo">

  <!-- Foto de fondo full-bleed con gradiente oscuro -->
  <div class="hero-bg" aria-hidden="true">
    <Image
      src={imgHero}
      alt=""
      width={1600}
      height={1000}
      loading="eager"
      decoding="async"
      class="hero-bg__img"
    />
  </div>

  <!-- Contenido tipográfico: texto vertical + H1 en fila flex alineados al top -->
  <div class="hero-content">
    <div class="hero-title-row">
      <div class="hero-vertical" aria-hidden="true">
        <span>BARRIO</span>
        <span>UNIVERSITARIO</span>
      </div>
      <h1 class="hero-h1" aria-label="Alzar el vuelo — TEDx Women">
        <span class="hero-h1__alzar display-light">ALZAR</span>
        <span class="hero-h1__el display-light">EL</span>
        <span class="hero-h1__vuelo display-black">VUELO</span>
      </h1>
    </div>
  </div>

</section>

<!-- ============================================================
     COUNTDOWN — Isla flotante solapada entre S1 y S2
     ============================================================ -->
<div class="cd-island-wrap">
  <div class="cd-island" role="timer" aria-label="Cuenta regresiva al evento">
    <span class="sr-only">El evento es el 4 de diciembre de 2026 a las 09:00 hrs.</span>
    <div class="cd-island__inner" aria-hidden="true">
      <div class="countdown-unit">
        <span class="countdown-label">DÍAS</span>
        <span class="countdown-num mono-date" id="cd-dias">--</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-unit">
        <span class="countdown-label">HORAS</span>
        <span class="countdown-num mono-date" id="cd-horas">--</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-unit">
        <span class="countdown-label">MINUTOS</span>
        <span class="countdown-num mono-date" id="cd-min">--</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-unit">
        <span class="countdown-label">SEGUNDOS</span>
        <span class="countdown-num mono-date" id="cd-seg">--</span>
      </div>
    </div>
  </div>
</div>


<!-- ============================================================
     S2 — EN COLABORACIÓN (equipo)
     Fondo claro. Grid 6 headshots reales.
     ============================================================ -->
<section id="equipo" class="s-equipo seccion-light texture-overlay" aria-labelledby="h-equipo">
  <div class="seccion-inner">

    <!-- Intro 2 columnas: título izq + párrafo der -->
    <div class="s-equipo__intro">
      <div class="s-equipo__intro-left">
        <p class="eyebrow-label s-equipo__eyebrow">
          UN EVENTO CONSTRUIDO <span class="flecha-roja" aria-hidden="true">→</span>
        </p>
        <h2 id="h-equipo" class="s-equipo__titulo display-black">EN COLABORACIÓN</h2>
      </div>
      <p class="s-equipo__desc">
        TEDxBarrioUniversitario Women es una iniciativa voluntaria y sin fines de lucro,
        orientada exclusivamente a crear un espacio para la difusión de ideas que inspiren
        transformación. Cada persona involucrada participa desde la convicción, el compromiso
        y el propósito de generar un impacto positivo en nuestra comunidad.
      </p>
    </div>

    <ul class="equipo-grid" role="list">
      {equipo.map(m => (
        <li class="equipo-card" role="listitem">
          <Image
            src={m.img}
            alt={m.nombre}
            width={300}
            height={400}
            loading="lazy"
            decoding="async"
            class="equipo-card__foto"
          />
          <div class="equipo-card__info">
            <p class="equipo-card__nombre headline-bold">{m.nombre}</p>
            <p class="equipo-card__cargo">{m.cargo}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>


<!-- ============================================================
     S3 — ¿QUÉ ES TEDx?
     Fondo oscuro. 1 col: texto full + SVG curvo decorativo.
     ============================================================ -->
<section id="que-es-tedx" class="s-que-es dark-section" aria-labelledby="h-que-es">

  <!-- Flecha curva punteada decorativa -->
  <svg class="s-que-es__deco" aria-hidden="true" viewBox="0 0 600 300" preserveAspectRatio="xMaxYMin slice">
    <path d="M620 10 C610 80 580 150 520 200 C460 250 360 270 20 255"
          stroke="rgba(255,255,255,0.22)" stroke-width="1.5" stroke-dasharray="7 4" fill="none"/>
    <polygon points="20,255 36,247 36,263" fill="#db0028"/>
  </svg>

  <div class="seccion-inner">
    <h2 id="h-que-es" class="s-que-es__h2">
      <span class="s-que-es__h2-top display-light">¿QUÉ ES</span>
      <span class="s-que-es__h2-bottom display-black"><span class="text-ted-red">TEDx</span>?</span>
    </h2>

    <div class="s-que-es__body">
      <p class="s-que-es__p">
        TEDx es un programa oficial de TED, la plataforma de difusión de ideas más reconocida del
        mundo. A través de una licencia oficial, permite organizar eventos independientes que
        mantienen los mismos estándares de excelencia, calidad y curaduría que han convertido a TED
        en un referente global.
      </p>
      <p class="s-que-es__p">
        Cada charla TEDx tiene el potencial de trascender el escenario local y formar parte de una
        conversación global, inspirando a miles de personas y comunidades alrededor del mundo.
      </p>
      <p class="s-que-es__p">
        Más que una conferencia, TEDx reúne a líderes, científicos, emprendedores, académicos y
        agentes de cambio para compartir ideas capaces de desafiar paradigmas y transformar
        realidades.
      </p>
      <p class="s-que-es__p">
        Ser parte de TEDxBarrioUniversitario Women es sumarse a una marca de prestigio internacional
        que impulsa conversaciones con impacto local y proyección global.
      </p>

      <div class="s-que-es__links">
        <a href="https://www.ted.com/tedx/events/69535" target="_blank" rel="noopener"
           class="s-que-es__link"
           aria-label="Evento oficial bajo licencia TEDx (abre en nueva pestaña)">
          <span class="flecha-roja" aria-hidden="true">→</span>
          Evento oficial bajo licencia TEDx
        </a>
        <a href="https://www.ted.com/tedx/events/69535" target="_blank" rel="noopener"
           class="s-que-es__link s-que-es__link--event"
           aria-label="Ver evento en TED.com, TEDxBarrioUniversitario Women (abre en nueva pestaña)">
          Ver evento en TED.com
          <span aria-hidden="true"> → </span>
          <span class="text-ted-red">TEDxBarrioUniversitario Women</span>
        </a>
      </div>
    </div>
  </div>
</section>


<!-- ============================================================
     S4 — ¿POR QUÉ TEDxWomen?
     Fondo claro + textura. Texto izquierda + polaroid derecho.
     ============================================================ -->
<section id="tedxwomen" class="s-mujeres seccion-light texture-overlay" aria-labelledby="h-mujeres">
  <div class="seccion-inner s-mujeres__inner">

    <!-- Col izquierda: texto -->
    <div class="s-mujeres__copy">
      <h2 id="h-mujeres" class="s-mujeres__h2">
        <span class="s-mujeres__h2-top display-light">¿POR QUÉ</span>
        <span class="s-mujeres__h2-bottom display-black">TEDxWomen?</span>
      </h2>

      <p class="s-mujeres__p">
        TEDxWomen No es un evento "sobre mujeres". Es un evento donde las mujeres son
        protagonistas del cambio.
      </p>
      <p class="s-mujeres__p">
        Hoy enfrentamos desafíos urgentes relacionados con liderazgo, innovación, bienestar,
        equidad de género y desarrollo sostenible.
      </p>
      <p class="s-mujeres__p">
        Estamos convencidos que las ideas tienen el poder de abrir nuevas posibilidades y
        movilizar acciones capaces de transformar realidades.
      </p>
      <p class="s-mujeres__p">
        TEDxBarrioUniversitario Women nace para visibilizar nuevas voces, compartir experiencias
        y generar conversaciones que inspiren cambios positivos desde la Región del Biobío hacia
        el mundo.
      </p>
    </div>

    <!-- Col derecha: foto full-bleed con encuadre de cámara -->
    <figure class="s-mujeres__foto-wrap">
      <Image
        src={imgFotoSec02}
        alt="Speaker TEDx en el escenario del Barrio Universitario"
        width={560}
        height={800}
        loading="lazy"
        decoding="async"
        class="s-mujeres__foto-bg"
      />
      <div class="s-mujeres__foto-frame" aria-hidden="true"></div>
      <figcaption class="s-mujeres__foto-cita">
        "Las ideas inspiran.<br/>El despegue las vuelve realidad"
      </figcaption>
    </figure>

  </div>
</section>


<!-- ============================================================
     S5 — ALZAR EL VUELO (concepto)
     Fondo oscuro. Título+copy 2-col, boarding pass fila completa, franja.
     ============================================================ -->
<section id="concepto" class="s-concepto dark-section" aria-labelledby="h-concepto">
  <div class="seccion-inner s-concepto__inner">

    <!-- Título izquierda con pesos mixtos -->
    <div class="s-concepto__title-col">
      <h2 id="h-concepto" class="s-concepto__h2">
        <span class="s-concepto__h2-l1 display-light">ALZAR</span>
        <span class="s-concepto__h2-l2 display-light">EL</span>
        <span class="s-concepto__h2-l3 display-black">VUELO</span>
      </h2>
    </div>

    <!-- 4 párrafos oficiales columna derecha -->
    <div class="s-concepto__copy-col">
      <p class="s-concepto__p">Alzar el Vuelo es una invitación a salir de lo conocido, explorar nuevos horizontes y descubrir el poder que tienen las ideas para transformar personas, organizaciones y comunidades.</p>
      <p class="s-concepto__p">En TEDxBarrioUniversitario Women, cada charla será una etapa de este viaje: un recorrido por experiencias, aprendizajes e historias que inspiran, desafían y movilizan a la acción.</p>
      <p class="s-concepto__p">Porque cuando una idea encuentra el momento y el lugar para ser compartida, tiene el poder de trascender y cambiar realidades.</p>
      <p class="s-concepto__p">Te invitamos a preparar tu despegue. <strong class="s-concepto__p-strong">El viaje comienza aquí.</strong></p>
    </div>
  </div>

  <!-- Boarding pass + avión: fila ancho-completo debajo de las columnas -->
  <div class="seccion-inner s-concepto__bp-row">
    <div class="boarding-pass s-bp" role="img"
         aria-label="Vuelo directo: IDEA 09:00 AM hasta ACCIÓN 13:00 PM, viernes 04 de diciembre">
      <div class="boarding-pass__col">
        <span class="boarding-pass__label">Origen</span>
        <span class="boarding-pass__valor">IDEA</span>
        <span class="boarding-pass__hora mono-date">09:00 AM</span>
        <span class="boarding-pass__hora">Vie 04 dic</span>
      </div>
      <div class="boarding-pass__divider">
        <span class="boarding-pass__directo">Directo</span>
      </div>
      <div class="boarding-pass__col s-bp__dest">
        <span class="boarding-pass__label">Destino</span>
        <span class="boarding-pass__valor">ACCIÓN</span>
        <span class="boarding-pass__hora mono-date">13:00 PM</span>
        <span class="boarding-pass__hora">Vie 04 dic</span>
      </div>
    </div>

    <!-- Avión SVG animateMotion -->
    <div class="s-avion" aria-hidden="true">
      <svg class="s-avion__svg" viewBox="0 0 460 80" width="460" height="80"
           xmlns="http://www.w3.org/2000/svg">
        <!-- Trayectoria punteada -->
        <path id="flight-path" d="M10 65 Q120 10 250 35 Q350 55 450 20"
              stroke="#afb5db" stroke-width="1.5" stroke-dasharray="6 4" fill="none"/>
        <!-- Avión que sigue la trayectoria -->
        <g id="avion-icon">
          <animateMotion dur="5s" repeatCount="indefinite" rotate="auto">
            <mpath href="#flight-path"/>
          </animateMotion>
          <!-- Silueta avión minimalista -->
          <polygon points="0,-8 18,0 0,8 4,0" fill="#db0028"/>
        </g>
      </svg>
    </div>
  </div>

  <!-- Franja inferior: sin aria-hidden (tagline con significado del docx) -->
  <div class="s-concepto__franja">
    <p class="s-concepto__franja-text display-light">
      TODA GRAN TRANSFORMACIÓN COMIENZA CON UNA IDEA
    </p>
  </div>
</section>


<!-- ============================================================
     S6 — FICHA TÉCNICA
     Fondo claro. Polaroid izquierda + datos + contadores + temáticas.
     ============================================================ -->
<section id="evento" class="s-ficha seccion-light" aria-labelledby="h-ficha">
  <div class="seccion-inner s-ficha__inner">

    <!-- Columna izquierda: polaroid + cita -->
    <div class="s-ficha__left">
      <div class="polaroid" aria-hidden="true">
        <Image
          src={imgFicha}
          alt=""
          width={360}
          height={480}
          loading="lazy"
          decoding="async"
          class="polaroid__img"
        />
        <div class="polaroid__caption">TEDxBarrioUniversitario Women 2026</div>
      </div>
      <blockquote class="caja-lavanda s-ficha__cita" style="margin-top:1.5rem;">
        <p>"Ideas capaces de cambiar perspectivas y generar acción"</p>
      </blockquote>
    </div>

    <!-- Columna derecha: datos + temáticas -->
    <div class="s-ficha__right">
      <p class="eyebrow-label">El evento</p>
      <h2 id="h-ficha" class="display-black s-ficha__h2">
        FICHA TÉCNICA <span class="flecha-roja" aria-hidden="true">→</span>
      </h2>

      <!-- 6 Temáticas -->
      <div class="s-ficha__tematicas">
        <p class="s-ficha__tematicas-label eyebrow-label" style="color:var(--color-charcoal); margin-bottom:10px;">Temáticas</p>
        <ul class="s-ficha__tematicas-list">
          {tematicas.map(t => (
            <li>
              <span class="flecha-roja" aria-hidden="true">→</span> {t}
            </li>
          ))}
        </ul>
      </div>

      <p class="s-ficha__desc">
        Más que un evento, buscamos construir una experiencia que conecte personas con ideas
        capaces de cambiar perspectivas y generar acción.
      </p>
    </div>
  </div>

  <!-- Franja inferior: Logo UdeC + contadores count-up -->
  <div class="s-ficha__franja">
    <div class="s-ficha__franja-inner">
      <div class="s-ficha__franja-udec">
        <img src={`${baseUrl}/partners/udec-negro.png`} alt="Universidad de Concepción"
             width="160" height="60" loading="lazy" decoding="async" class="s-ficha__udec-logo"/>
        <p class="s-ficha__udec-label">Campus sede del evento</p>
      </div>
      <div class="s-ficha__franja-sep" aria-hidden="true"></div>
      <ul class="s-ficha__counters" aria-label="Datos del evento">
        <li class="counter-item">
          <span class="counter-num mono-date js-counter"
                data-target={evento.asistentes}
                aria-label={`${evento.asistentes} asistentes presenciales`}></span>
          <span class="counter-label">Asistentes presenciales</span>
        </li>
        <li class="counter-item">
          <span class="counter-num mono-date js-counter"
                data-target={evento.speakers}
                data-pad="2"
                aria-label={`${evento.speakers} speakers seleccionados`}></span>
          <span class="counter-label">Speakers seleccionados</span>
        </li>
        <li class="counter-item">
          <span class="counter-num mono-date js-counter"
                data-target={evento.ideas}
                data-pad="2"
                aria-label={`${evento.ideas} idea de alto impacto`}></span>
          <span class="counter-label">Idea de alto impacto</span>
        </li>
      </ul>
    </div>
  </div>
</section>


<!-- ============================================================
     S7 — ¿POR QUÉ SUMARSE COMO AUSPICIADOR?
     Fondo oscuro. Bullets izquierda + 2 polaroids rotadas derecha.
     ============================================================ -->
<section id="auspiciadores" class="s-auspi dark-section" aria-labelledby="h-auspi">
  <div class="seccion-inner s-auspi__inner">

    <!-- Col izquierda: texto -->
    <div class="s-auspi__copy">
      <p class="eyebrow-label">¿Por qué sumarse?</p>
      <h2 id="h-auspi" class="display-black s-auspi__h2">
        ¿POR QUÉ SUMARSE<br/>COMO AUSPICIADOR?
      </h2>
      <p class="s-auspi__intro">
        Al convertirse en partner de TEDxBarrioUniversitario Women, su organización no solo
        financia un evento — se integra a una plataforma de impacto con propósito real y
        estará contribuyendo a:
      </p>
      <ul class="s-auspi__bullets">
        {[
          'Impulsar educación, cultura y pensamiento crítico',
          'Promover liderazgo femenino y equidad de género',
          'Inspirar nuevas generaciones',
          'Potenciar innovación y desarrollo sostenible',
          'Fortalecer el ecosistema regional',
          'Generar impacto social positivo desde el Biobío',
        ].map(b => (
          <li class="s-auspi__bullet">
            <span class="flecha-roja" aria-hidden="true">→</span>
            {b}
          </li>
        ))}
      </ul>

      <blockquote class="s-auspi__cita">
        <p class="s-auspi__cita-text">
          <span class="comilla-roja" aria-hidden="true">"</span>
          Las ideas necesitan espacios para despegar.
          <span class="comilla-roja" aria-hidden="true">"</span>
        </p>
      </blockquote>
    </div>

    <!-- Col derecha: 2 polaroids rotadas -->
    <div class="s-auspi__polars" aria-hidden="true">
      <div class="polaroid polaroid--rotate-left">
        <Image
          src={imgAuspPolar}
          alt=""
          width={340}
          height={260}
          loading="lazy"
          decoding="async"
          class="polaroid__img"
        />
        <div class="polaroid__caption">Alcance · Presencia · Impacto</div>
      </div>
      <div class="polaroid polaroid--rotate-right" style="margin-top:1.5rem;">
        <Image
          src={imgAuspPolar}
          alt=""
          width={340}
          height={260}
          loading="lazy"
          decoding="async"
          class="polaroid__img"
        />
        <div class="polaroid__caption">Ideas que conectan organizaciones</div>
      </div>
    </div>

  </div>
</section>


<!-- ============================================================
     S8 — BENEFICIOS PARA SU ORGANIZACIÓN
     Fondo claro. 4 en fila + CTA formulario.
     ============================================================ -->
<section id="beneficios" class="s-beneficios seccion-light texture-overlay" aria-labelledby="h-beneficios">
  <div class="seccion-inner">

    <!-- Header 2 columnas: H2 izquierda · párrafo derecha -->
    <div class="s-beneficios__header">
      <div class="s-beneficios__header-left">
        <p class="eyebrow-label">Lo que obtendrá</p>
        <h2 id="h-beneficios" class="display-black s-beneficios__h2">BENEFICIOS <span style="font-weight:300;">PARA SU ORGANIZACIÓN</span></h2>
      </div>
      <div class="s-beneficios__header-right">
        <p class="s-beneficios__intro">
          ¿Te gustaría ser parte de este viaje? Si tu organización comparte nuestro propósito
          y quiere asociarse a una plataforma de prestigio internacional que promueve la
          innovación, el conocimiento y la transformación social, nos encantaría conversar contigo.
        </p>
      </div>
    </div>

    <!-- Fila minimalista de beneficios -->
    <ul class="beneficios-fila" aria-label="Beneficios para su organización">
      {beneficios.map((b, i) => (
        <li class="beneficio-item">
          <span class="flecha-roja beneficio-flecha" aria-hidden="true">→</span>
          <span class="beneficio-nombre headline-bold">{b.titulo.toUpperCase()}</span>
          {i < beneficios.length - 1 && (
            <span class="beneficio-sep" aria-hidden="true"></span>
          )}
        </li>
      ))}
    </ul>

    <!-- CTA → form Formspree alianzas -->
    <div class="s-beneficios__cta">
      <a href="#form-partner" class="btn-primary">Quiero ser Partner →</a>
    </div>

    <!-- Formulario de alianza (tabindex="-1" para foco desde CTA — a11y F-06) -->
    <div id="form-partner" class="s-beneficios__form" tabindex="-1">
      <h3 class="s-beneficios__form-title headline-bold">Escríbenos para auspiciar</h3>
      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        class="form-partner"
        aria-label="Formulario de solicitud de auspicio"
      >
        <input type="hidden" name="_tipo" value="partner"/>
        <!-- Honeypot anti-spam WCAG 3.3.2 -->
        <input type="text" name="_gotcha" tabindex="-1" aria-hidden="true"
               style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;"/>

        <div class="form-partner__row">
          <div class="form-partner__field">
            <label class="form-partner__label" for="p-nombre">Nombre y organización</label>
            <input id="p-nombre" name="nombre" type="text" required
                   placeholder="Ej. Cristian Sánchez · ANAMI Spa"
                   class="form-partner__input" autocomplete="name"/>
          </div>
          <div class="form-partner__field">
            <label class="form-partner__label" for="p-email">Correo electrónico</label>
            <input id="p-email" name="email" type="email" required
                   placeholder="contacto@suempresa.cl"
                   class="form-partner__input" autocomplete="email"/>
          </div>
        </div>
        <div class="form-partner__field">
          <label class="form-partner__label" for="p-mensaje">¿Cómo le gustaría participar?</label>
          <textarea id="p-mensaje" name="mensaje" rows="4" required
                    placeholder="Cuéntenos sobre su organización y el tipo de auspicio que le interesa…"
                    class="form-partner__input form-partner__textarea"></textarea>
        </div>
        <button type="submit" class="btn-primary">Enviar solicitud →</button>
      </form>
    </div>

  </div>
</section>


<!-- ============================================================
     S9 — CONVOCATORIA DE SPEAKERS
     Fondo mixto (claro). Silueta TU NOMBRE + proceso 3 etapas + form.
     ============================================================ -->
<section id="speakers" class="s-speakers seccion-light" aria-labelledby="h-speakers">
  <div class="seccion-inner">

    <div class="s-speakers__header">
      <p class="eyebrow-label">Convocatoria</p>
      <h2 id="h-speakers" class="display-black s-speakers__h2">CONVOCATORIA DE SPEAKERS</h2>
      <p class="s-speakers__sub">¿Tienes una idea que merece ser compartida?</p>
    </div>

    <div class="s-speakers__layout">

      <!-- Imagen silueta "TU NOMBRE" -->
      <div class="s-speakers__photo">
        <div class="s-speakers__photo-wrap">
          <Image
            src={imgConvoca}
            alt="Silueta de speaker en el escenario — Tu nombre podría estar aquí"
            width={420}
            height={560}
            loading="lazy"
            decoding="async"
            class="s-speakers__photo-img"
          />
          <div class="s-speakers__tu-nombre display-black" aria-hidden="true">TU NOMBRE</div>
        </div>
      </div>

      <!-- Info + proceso + form -->
      <div class="s-speakers__info">

        <div class="s-speakers__quienes">
          <p class="s-speakers__quienes-desc">
            En TEDxBarrioUniversitario Women buscamos personas que compartan ideas capaces de
            desafiar paradigmas, abrir nuevas conversaciones y generar un impacto positivo en
            la sociedad.
          </p>
          <p class="s-speakers__quienes-desc">
            No es necesario ser un conferencista profesional. Lo más importante es que tu idea
            sea original, relevante y tenga el potencial de inspirar.
          </p>
          <h3 class="headline-bold s-speakers__quienes-h">¿Quiénes pueden postular?</h3>
          <p class="s-speakers__quienes-sub">
            La convocatoria está abierta a personas mayores de 18 años con iniciativas relacionadas con:
          </p>
          <ul class="s-speakers__quienes-list">
            {[
              'Liderazgo femenino',
              'Equidad de género e inclusión',
              'Emprendimiento e innovación',
              'Bienestar y calidad de vida',
              'Impacto social y sostenibilidad',
            ].map(item => (
              <li class="s-speakers__quienes-item">
                <span class="flecha-roja" aria-hidden="true">→</span> {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Proceso 3 etapas -->
        <div class="s-proceso" aria-label="Proceso de postulación en 3 etapas">
          {procesoSpeaker.map((e, i) => (
            <div class="s-proceso__step">
              <div class="s-proceso__num mono-date" aria-hidden="true">{e.num}</div>
              <div class="s-proceso__content">
                <h4 class="s-proceso__title headline-bold">{e.titulo}</h4>
                <p class="s-proceso__desc">{e.desc}</p>
              </div>
              {i < procesoSpeaker.length - 1 && (
                <div class="s-proceso__connector" aria-hidden="true"></div>
              )}
            </div>
          ))}
        </div>

        <!-- Formulario speaker → Formspree -->
        <!-- tabindex="-1" permite foco programático desde CTA — a11y F-07 -->
        <div id="form-speaker" class="s-speakers__form" tabindex="-1">
          <h3 class="s-speakers__form-title headline-bold">POSTULA COMO SPEAKER</h3>
          <p class="s-speakers__form-sub">¿Listo para alzar el vuelo con tu idea?</p>
          <form
            action={`https://formspree.io/f/${FORMSPREE_ID}`}
            method="POST"
            class="form-speaker"
            aria-label="Formulario de postulación como speaker"
          >
            <input type="hidden" name="_tipo" value="postulacion-speaker"/>
            <input type="text" name="_gotcha" tabindex="-1" aria-hidden="true"
                   style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;"/>

            <div class="form-speaker__row">
              <div class="form-speaker__field">
                <label class="form-label" for="sp-nombre">Nombre completo</label>
                <input id="sp-nombre" name="nombre" type="text" required
                       placeholder="Tu nombre"
                       class="form-input" autocomplete="name"/>
              </div>
              <div class="form-speaker__field">
                <label class="form-label" for="sp-email">Correo electrónico</label>
                <input id="sp-email" name="email" type="email" required
                       placeholder="tu@correo.cl"
                       class="form-input" autocomplete="email"/>
              </div>
            </div>
            <div class="form-speaker__field">
              <label class="form-label" for="sp-idea">Tu idea en una frase</label>
              <input id="sp-idea" name="idea" type="text" required
                     placeholder="Ej. Cómo el diseño regenerativo puede salvar el Biobío"
                     class="form-input"/>
            </div>
            <div class="form-speaker__field">
              <label class="form-label" for="sp-descripcion">Cuéntanos más sobre tu idea</label>
              <textarea id="sp-descripcion" name="descripcion" rows="4" required
                        placeholder="¿Por qué esta idea importa? ¿A quién le puede cambiar la perspectiva?"
                        class="form-input" style="resize:vertical;"></textarea>
            </div>
            <button type="submit" class="btn-primary">POSTULA COMO SPEAKER →</button>
          </form>
        </div>

      </div>
    </div>

  </div>
</section>


<!-- ============================================================
     S10 — NUESTROS PARTNERS
     Fondo claro. Carrusel 5 categorías.
     ============================================================ -->
<section id="partners" class="s-partners seccion-light texture-overlay" aria-labelledby="h-partners">
  <div class="seccion-inner">

    <div class="s-partners__header">
      <p class="eyebrow-label">Partners</p>
      <h2 id="h-partners" class="display-black s-partners__h2">NUESTROS PARTNERS</h2>
      <p class="s-partners__sub">Las grandes ideas necesitan grandes aliados.</p>
      <p class="s-partners__desc">
        TEDxBarrioUniversitario Women es posible gracias a instituciones, empresas y organizaciones
        que creen en el poder de las ideas para transformar realidades. Agradecemos profundamente
        a quienes han decidido sumarse a este viaje y hacerlo posible.
      </p>
    </div>

    <!-- Carrusel -->
    <div class="partners-carousel" role="region" aria-label="Carrusel de categorías de partners">
      <button class="partners-prev" aria-label="Categoría anterior" id="btn-prev">‹</button>

      <div class="partners-track-wrap">
        <div class="partners-track" id="partners-track">
          {partners.map((p, i) => (
            <div class="partners-slide" role="group" aria-label={`Categoría ${i+1} de ${partners.length}: ${p.categoria}`}
                 id={`slide-${i}`}>
              <p class="partners-slide__cat eyebrow-label" style="color:var(--color-charcoal);">{p.categoria}</p>
              <div class="partners-slide__logos">
                {p.categoria === 'Institución Anfitriona' && (
                  <img src={`${baseUrl}/partners/udec-negro.png`}
                       alt="Universidad de Concepción"
                       width="200" height="75" loading="lazy" decoding="async"
                       class="partners-logo"/>
                )}
                {p.categoria === 'Estratégico' && (
                  <div class="partners-placeholder partners-placeholder--anami">
                    <span class="display-black" style="font-size:1.2rem; color:var(--color-charcoal);">ANAMI Studio</span>
                    <span style="font-size:0.7rem; color:rgba(35,35,35,0.6);">Desarrollo web & software</span>
                  </div>
                )}
                {p.placeholder && (
                  <div class="partners-placeholder">
                    <span>Logo partner · <em>{p.categoria}</em></span>
                    <span style="font-size:0.65rem; color:rgba(35,35,35,0.5);">Próximamente</span>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      <button class="partners-next" aria-label="Categoría siguiente" id="btn-next">›</button>
    </div>

    <!-- Indicadores — grupo de botones (no tab pattern: no hay panels navegables) -->
    <div class="partners-dots" role="group" aria-label="Navegar categorías de partners" id="partners-dots">
      {partners.map((p, i) => (
        <button class={`partners-dot${i === 0 ? ' partners-dot--active' : ''}`}
                aria-label={p.categoria} data-idx={i} id={`dot-${i}`}
                aria-pressed={i === 0 ? 'true' : 'false'}>
        </button>
      ))}
    </div>
    <!-- Live region para anuncios del carrusel (FINDING-10) -->
    <div id="carousel-announce" aria-live="polite" aria-atomic="true" class="sr-only"></div>

    <!-- CTA auspiciar -->
    <p class="s-partners__cta-text">
      ¿Tu organización quiere ser parte?
      <a href="#form-partner" class="text-ted-red s-partners__link">Conversemos →</a>
    </p>

  </div>
</section>


<!-- ============================================================
     S11 — CONTACTO
     Fondo oscuro. Izq: datos + socials. Der: foto + cita.
     ============================================================ -->
<section id="contacto" class="s-contacto dark-section" aria-labelledby="h-contacto">
  <div class="seccion-inner s-contacto__inner">

    <!-- Col izquierda: datos -->
    <div class="s-contacto__copy">
      <p class="eyebrow-label">Contacto</p>
      <h2 id="h-contacto" class="display-black s-contacto__h2">CONTACTO</h2>
      <p class="s-contacto__subtitulo">¿Quieres ser parte de este viaje?</p>
      <p class="s-contacto__intro">
        Si deseas colaborar, convertirte en partner, postular como speaker o conocer más sobre
        TEDxBarrioUniversitario Women, estaremos encantados de conversar contigo.
      </p>

      <a href={`mailto:${evento.email}`} class="s-contacto__email headline-bold">
        {evento.email}
      </a>

      <p class="s-contacto__redes-label">Síguenos en</p>
      <div class="s-contacto__redes" role="list" aria-label="Redes sociales">
        <!-- Instagram -->
        <a href={`https://instagram.com/${evento.ig.replace('@', '')}`}
           target="_blank" rel="noopener"
           class="s-contacto__red" role="listitem"
           aria-label="Instagram de TEDxBarrioUniversitario Women (abre en nueva pestaña)">
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          <span>{evento.ig}</span>
        </a>
        <!-- LinkedIn -->
        <a href={`https://linkedin.com/company/${evento.linkedin}`}
           target="_blank" rel="noopener"
           class="s-contacto__red" role="listitem"
           aria-label="LinkedIn de TEDxBarrioUniversitario Women (abre en nueva pestaña)">
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.8">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          <span>LinkedIn</span>
        </a>
        <!-- Flickr -->
        <a href={`https://flickr.com/people/${evento.flickr}`}
           target="_blank" rel="noopener"
           class="s-contacto__red" role="listitem"
           aria-label="Flickr de TEDxBarrioUniversitario Women (abre en nueva pestaña)">
          <!-- Icono Flickr: dos círculos -->
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="7" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8"/>
            <circle cx="17" cy="12" r="4.5" stroke="currentColor" stroke-width="1.8"/>
          </svg>
          <span>Flickr</span>
        </a>
      </div>
    </div>

    <!-- Col derecha: foto + cita -->
    <div class="s-contacto__photo-col">
      <div class="s-contacto__photo-wrap parallax-img">
        <Image
          src={imgContacto}
          alt="Audiencia del evento TEDxBarrioUniversitario Women"
          width={600}
          height={400}
          loading="lazy"
          decoding="async"
          class="s-contacto__photo-img"
        />
      </div>
      <blockquote class="caja-lavanda s-contacto__cita" style="margin-top:1.25rem;">
        <p>"Las grandes ideas comienzan con una conversación."</p>
      </blockquote>
    </div>

  </div>
</section>


<!-- ============================================================
     ESTILOS de sección (complementan global.css y BaseLayout)
     ============================================================ -->
<style>

/* ── UTILIDADES ─────────────────────────────────────────────── */
.seccion-light  { background: var(--color-surface); }
.seccion-inner  { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
.seccion-2col   { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.text-ted-red   { color: var(--color-ted-red); }

.flecha-roja {
  color: var(--color-ted-red);
  font-weight: 700;
  font-style: normal;
  font-size: 1.1em;
}

/* ── S1 HERO ────────────────────────────────────────────────── */
.s-hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding-top: 70px; /* compensar header fijo */
}

/* Foto full-bleed con gradiente oscuro izquierda→derecha */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.82) 0%,
    rgba(0,0,0,0.65) 40%,
    rgba(0,0,0,0.30) 70%,
    rgba(0,0,0,0.10) 100%
  );
}
.hero-bg__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* Fila con texto vertical + H1 en paralelo */
.hero-title-row {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

/* BARRIO | UNIVERSITARIO — flex row; writing-mode en cada span para orden predecible */
.hero-vertical {
  display: flex;
  align-items: flex-start;
  gap: 0.3rem;
  flex-shrink: 0;
  font-family: var(--font-display);
  font-weight: 700;
  /* font-size calibrado para que UNIVERSITARIO (13 chars × 1.28) ≈ altura del H1 */
  font-size: clamp(1.1rem, 2.2vw, 1.9rem);
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  line-height: 1;
}
/* Cada span es un flex item con vertical-lr: top→bottom, orden BARRIO|UNIVERSITARIO */
.hero-vertical span {
  writing-mode: vertical-lr;
}

/* Área de contenido tipográfico */
.hero-content {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 2rem 3rem;
}

.hero-h1 {
  display: flex;
  flex-direction: column;
  line-height: 0.88;
  gap: 0;
  margin: 0;
}
.hero-h1__alzar,
.hero-h1__el {
  font-size: clamp(5rem, 12vw, 11rem);
  color: rgba(255,255,255,0.95);
}
.hero-h1__vuelo {
  font-size: clamp(6.5rem, 15vw, 14rem);
  color: #ffffff;
}

/* ── COUNTDOWN ISLA FLOTANTE ─────────────────────────────────── */
.cd-island-wrap {
  position: relative;
  z-index: 20;
  display: flex;
  justify-content: center;
  padding: 0 1.5rem;
  margin-top: -4rem; /* solapa sobre el bottom del hero */
}
.cd-island {
  background: #111;
  border-radius: 20px;
  padding: 1.75rem 2.5rem;
  max-width: 900px;
  width: 100%;
  box-shadow: 0 12px 48px rgba(0,0,0,0.55);
}
.cd-island__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}
.countdown-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.countdown-label {
  font-family: var(--font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65); /* ~5.0:1 ✓ WCAG AA */
  order: -1; /* etiqueta arriba del número */
}
.countdown-num {
  font-size: clamp(2.8rem, 7vw, 5rem);
  color: #ffffff;
  line-height: 1;
  background: #1e1e1e;
  border-radius: 8px;
  padding: 0.2rem 0.75rem;
  min-width: 2.5ch;
  text-align: center;
}
.countdown-sep {
  font-family: var(--font-mono);
  font-weight: 700;
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--color-ted-red);
  align-self: flex-end;
  padding-bottom: 0.2rem;
  margin-top: 1.4rem; /* alinear con los números, bajo las etiquetas */
}

/* ── S2 EQUIPO ──────────────────────────────────────────────── */
.s-equipo {
  padding: var(--spacing-section) 0;
  padding-top: 7rem; /* espacio para la isla countdown solapada */
}

/* Intro 2 columnas */
.s-equipo__intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  margin-bottom: 3.5rem;
}
.s-equipo__intro-left { /* vacío: solo organiza el grid */ }
.s-equipo__eyebrow {
  margin-bottom: 0.5rem;
  color: var(--color-charcoal);
  font-size: 1rem;
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
}
.s-equipo__eyebrow .flecha-roja { font-size: 1.6em; line-height: 1; }
.s-equipo__titulo {
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--color-charcoal);
  margin-top: 0.25rem;
  line-height: 0.95;
}
.s-equipo__desc {
  color: rgba(35,35,35,0.78);
  line-height: 1.7;
  font-size: 1rem;
  font-family: var(--font-sans);
}

.equipo-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 1.25rem;
  list-style: none;
  padding: 0;
  margin: 0;
}

.equipo-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 4px;
  border: 1px solid rgba(35,35,35,0.12);
  background: #fff;
}
.equipo-card__foto {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: center top;
  display: block;
}
.equipo-card__info {
  padding: 0.75rem 0.875rem;
  background: #fff; /* blanco — no lavanda */
  border-top: 1px solid rgba(35,35,35,0.08);
  text-align: center;
}
.equipo-card__nombre {
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-charcoal);
  margin: 0 0 3px;
}
.equipo-card__cargo {
  font-size: 0.72rem;
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  color: rgba(35,35,35,0.62);
  font-family: var(--font-sans);
  margin: 0;
  line-height: 1.4;
}

/* ── S3 ¿QUÉ ES TEDx? ──────────────────────────────────────── */
.s-que-es {
  padding: var(--spacing-section) 0;
  background: var(--color-charcoal);
  position: relative;
  overflow: hidden;
}
.s-que-es__deco {
  position: absolute;
  top: 0;
  right: 0;
  width: 55%;
  max-width: 680px;
  height: auto;
  pointer-events: none;
}
.s-que-es__h2 {
  display: flex;
  flex-direction: column;
  color: #fff;
  margin-bottom: 2.5rem;
  line-height: 1;
}
.s-que-es__h2-top {
  font-size: clamp(1.4rem, 2.8vw, 2.2rem);
  color: #fff;
}
.s-que-es__h2-bottom {
  font-size: clamp(4rem, 10vw, 9rem);
  color: #fff;
  line-height: 0.88;
}
.s-que-es__body { max-width: 860px; }
.s-que-es__p {
  color: rgba(255,255,255,0.82);
  line-height: 1.65;
  margin-bottom: 1rem;
}
.s-que-es__links { display: flex; flex-direction: column; gap: 0.5rem; margin-top: 2rem; }
.s-que-es__link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #fff;
  text-decoration: none;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.9rem;
  transition: color 0.15s;
}
.s-que-es__link:hover { color: var(--color-ted-red); }
.s-que-es__link--event {
  font-weight: 400;
  font-family: var(--font-sans);
  font-size: 0.88rem;
}

/* ── S4 ¿POR QUÉ TEDxWOMEN? ──────────────────────────────── */
.s-mujeres { padding: var(--spacing-section) 0; }
.s-mujeres__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.s-mujeres__h2 {
  display: flex;
  flex-direction: column;
  color: var(--color-charcoal);
  line-height: 1;
  margin: 0 0 1.5rem;
}
.s-mujeres__h2-top {
  font-size: clamp(1.2rem, 2.4vw, 1.9rem);
}
.s-mujeres__h2-bottom {
  font-size: clamp(2.6rem, 6vw, 4.5rem);
  line-height: 0.9;
}
.s-mujeres__p {
  color: rgba(35,35,35,0.8);
  line-height: 1.65;
  margin-bottom: 1rem;
  max-width: 46ch;
}
.s-mujeres__foto-wrap {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  max-width: 480px;
  margin: 0 auto;
}
.s-mujeres__foto-bg {
  width: 100%;
  aspect-ratio: 3/4;
  object-fit: cover;
  object-position: center center;
  display: block;
}
.s-mujeres__foto-frame {
  position: absolute;
  top: 6%;
  left: 6%;
  right: 6%;
  bottom: 22%;
  border: 3px solid rgba(255,255,255,0.88);
  border-radius: 6px;
  pointer-events: none;
}
.s-mujeres__foto-cita {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  text-align: center;
  font-style: italic;
  font-weight: 700;
  font-family: var(--font-display);
  font-size: 0.9rem;
  color: #fff;
  line-height: 1.3;
  padding: 0.75rem 1rem 1rem;
  background: rgba(0,0,0,0.45);
}

/* ── S5 ALZAR EL VUELO (concepto) ──────────────────────────── */
.s-concepto {
  background: var(--color-charcoal);
  padding: var(--spacing-section) 0 0;
}
.s-concepto__inner {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 3rem;
  align-items: start;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem 2.5rem;
}
.s-concepto__h2 {
  display: flex;
  flex-direction: column;
  color: #ffffff;
  line-height: 0.92;
  margin: 0;
}
.s-concepto__h2-l1 { font-size: clamp(2.6rem, 7vw, 6rem); letter-spacing: 0.12em; }
.s-concepto__h2-l2 { font-size: clamp(2.6rem, 7vw, 6rem); letter-spacing: 0.12em; }
.s-concepto__h2-l3 { font-size: clamp(2.8rem, 7.5vw, 6.5rem); letter-spacing: -0.01em; }
.s-concepto__copy-col { padding-top: 0.5rem; }
.s-concepto__p {
  color: rgba(255,255,255,0.82);
  font-family: var(--font-sans);
  font-size: 0.95rem;
  line-height: 1.6;
  margin: 0 0 1rem;
  max-width: 48ch;
}
.s-concepto__p:last-child { margin-bottom: 0; }
.s-concepto__p-strong { color: #fff; font-weight: 700; }

/* Boarding pass fila ancho-completo */
.s-concepto__bp-row {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem 1.5rem;
}
.s-bp {
  background: var(--color-lavanda);
  margin-bottom: 1.5rem;
}
.s-bp__dest { text-align: right; }

/* Avión SVG */
.s-avion { padding: 0.5rem 0; }
.s-avion__svg { width: 100%; max-width: 460px; height: auto; overflow: visible; }

/* Franja inferior: sin fondo rojo — texto blanco sobre charcoal */
.s-concepto__franja {
  padding: 1rem 1.5rem;
  text-align: center;
  overflow: hidden;
}
.s-concepto__franja-text {
  color: #ffffff;
  font-size: clamp(0.7rem, 1.8vw, 0.9rem);
  letter-spacing: 0.18em;
  margin: 0;
  white-space: nowrap;
}

/* ── S6 FICHA TÉCNICA ──────────────────────────────────────── */
.s-ficha { padding: var(--spacing-section) 0 0; }
.s-ficha__inner {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4rem;
  align-items: start;
}

/* Polaroid */
.polaroid {
  background: #fff;
  padding: 10px 10px 2.5rem;
  box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  border-radius: 2px;
  display: inline-block;
}
.polaroid__img { display: block; width: 100%; height: auto; }
.polaroid__caption {
  font-family: var(--font-display);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(35,35,35,0.65);
  text-align: center;
  margin-top: 0.5rem;
}
.polaroid--rotate-left  { transform: rotate(-3deg); }
.polaroid--rotate-right { transform: rotate(3deg); }

.s-ficha__right { display: flex; flex-direction: column; gap: 1.25rem; }
.s-ficha__h2 {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  color: var(--color-charcoal);
  margin: 0.4rem 0 0;
}
.s-ficha__desc {
  font-size: 0.92rem;
  color: rgba(35,35,35,0.75);
  line-height: 1.6;
  margin: 0;
}

/* Franja inferior de contadores */
.s-ficha__franja {
  margin-top: 3rem;
  border-top: 1.5px solid rgba(35,35,35,0.1);
  padding: 2rem 0;
  background: var(--color-surface);
}
.s-ficha__franja-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--px);
  display: flex;
  align-items: center;
  gap: 3rem;
  flex-wrap: wrap;
}
.s-ficha__franja-udec { display: flex; flex-direction: column; gap: 0.4rem; }
.s-ficha__udec-logo { height: 44px; width: auto; object-fit: contain; }
.s-ficha__udec-label {
  font-family: var(--font-display);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(35,35,35,0.6);
}
.s-ficha__franja-sep {
  width: 1px; height: 60px;
  background: rgba(35,35,35,0.15);
  flex-shrink: 0;
}

/* Contadores (ahora dentro de <ul> en la franja) */
.s-ficha__counters {
  display: flex; gap: 2.5rem; flex-wrap: wrap;
  list-style: none; padding: 0; margin: 0;
}
.counter-item { display: flex; flex-direction: column; align-items: flex-start; }
.counter-num {
  font-size: clamp(2.5rem, 6vw, 4rem);
  color: var(--color-charcoal);
  line-height: 1;
}
.counter-label {
  font-family: var(--font-display);
  font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  color: rgba(35,35,35,0.75);
  margin-top: 2px;
}

/* Temáticas */
.s-ficha__tematicas-list {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.s-ficha__tematicas-list li {
  display: flex; align-items: flex-start; gap: 8px;
  font-size: 0.88rem; color: rgba(35,35,35,0.8); line-height: 1.45;
}

/* ── S7 AUSPICIADORES ─────────────────────────────────────── */
.s-auspi { padding: var(--spacing-section) 0; background: var(--color-charcoal); }
.s-auspi__inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 4rem;
  align-items: start;
}
.s-auspi__h2 {
  font-size: clamp(1.6rem, 4vw, 2.8rem);
  color: #ffffff;
  margin: 0.5rem 0 1.5rem;
}
.s-auspi__intro {
  font-size: 0.92rem; color: rgba(255,255,255,0.75); line-height: 1.6;
  margin: 0 0 1.25rem;
}
.s-auspi__bullets { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
.s-auspi__bullet {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 0.9rem; color: rgba(255,255,255,0.82); line-height: 1.55;
}
.s-auspi__cita { border-left: 3px solid var(--color-ted-red); padding-left: 1rem; }
.s-auspi__cita-text {
  font-size: 1.1rem; font-style: italic;
  color: rgba(255,255,255,0.85); line-height: 1.55;
}
.s-auspi__polars { display: flex; flex-direction: column; gap: 0.25rem; max-width: 320px; }

/* ── S8 BENEFICIOS ────────────────────────────────────────── */
.s-beneficios { padding: var(--spacing-section) 0; }
.s-beneficios__header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: end;
  margin-bottom: 2.5rem;
}
.s-beneficios__h2 {
  font-size: clamp(1.6rem, 4vw, 3rem);
  color: var(--color-charcoal);
  margin-top: 0.5rem;
}
.s-beneficios__intro {
  font-size: 0.92rem; color: rgba(35,35,35,0.7); line-height: 1.65;
}

/* Fila minimalista de beneficios */
.beneficios-fila {
  list-style: none; padding: 0; margin: 0 0 2.5rem;
  display: flex; align-items: center; gap: 0; flex-wrap: wrap;
  border-top: 1.5px solid rgba(35,35,35,0.1);
  border-bottom: 1.5px solid rgba(35,35,35,0.1);
}
.beneficio-item {
  display: flex; align-items: center; gap: 0.5rem;
  padding: 1.25rem 1.5rem;
  flex: 1 1 auto;
  position: relative;
}
.beneficio-item:not(:last-child) { border-right: 1.5px solid rgba(35,35,35,0.1); }
.beneficio-flecha { font-size: 1.1rem; flex-shrink: 0; }
.beneficio-nombre {
  font-size: 0.78rem; letter-spacing: 0.07em;
  color: var(--color-charcoal);
}
.beneficio-sep { display: none; }

.s-beneficios__cta { text-align: center; margin-bottom: 3rem; }
.s-beneficios__form { max-width: 700px; margin: 0 auto; }
.s-beneficios__form-title {
  font-size: 1.3rem; color: var(--color-charcoal); margin-bottom: 1.5rem; text-align: center;
}

.form-partner { display: flex; flex-direction: column; gap: 1rem; }
.form-partner__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-partner__field { display: flex; flex-direction: column; gap: 0.35rem; }
.form-partner__label {
  font-family: var(--font-display);
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--color-charcoal);
}
.form-partner__input {
  width: 100%;
  background: #fff;
  border: 1.5px solid rgba(35,35,35,0.2);
  border-radius: 4px;
  padding: 10px 14px;
  font-family: var(--font-sans);
  font-size: 0.9rem;
  color: var(--color-charcoal);
  transition: border-color 0.15s;
  box-sizing: border-box;
}
.form-partner__input::placeholder { color: rgba(35,35,35,0.4); }
.form-partner__input:focus-visible {
  outline: 2px solid var(--color-ted-red);
  outline-offset: 1px;
  border-color: var(--color-ted-red);
}
.form-partner__input:focus:not(:focus-visible) { outline: none; border-color: var(--color-ted-red); }
.form-partner__textarea { resize: vertical; min-height: 100px; }

/* ── S9 SPEAKERS ──────────────────────────────────────────── */
.s-speakers { padding: var(--spacing-section) 0; }
.s-speakers__header { text-align: center; margin-bottom: 3rem; }
.s-speakers__h2 { font-size: clamp(1.8rem, 4vw, 3rem); color: var(--color-charcoal); margin: 0.5rem 0 0.75rem; }
.s-speakers__sub { color: rgba(35,35,35,0.7); font-size: 1rem; }

.s-speakers__layout {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4rem;
  align-items: start;
}
.s-speakers__photo-wrap {
  position: relative;
  display: inline-block;
}
.s-speakers__photo-img { display: block; border-radius: 4px; max-width: 380px; }
.s-speakers__tu-nombre {
  position: absolute;
  bottom: 1.5rem;
  left: 0; right: 0;
  text-align: center;
  color: #fff;
  font-size: 1.3rem;
  letter-spacing: 0.12em;
  text-shadow: 0 2px 8px rgba(0,0,0,0.5);
}

.s-speakers__quienes { margin-bottom: 2rem; }
.s-speakers__quienes-desc {
  font-size: 0.88rem; color: rgba(35,35,35,0.72); line-height: 1.6; margin: 0 0 0.85rem;
}
.s-speakers__quienes-sub {
  font-size: 0.85rem; color: rgba(35,35,35,0.65); line-height: 1.5; margin: 0 0 0.6rem;
}
.s-speakers__quienes-h { font-size: 1.05rem; color: var(--color-charcoal); margin-bottom: 0.5rem; margin-top: 1rem; }
.s-speakers__quienes-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.45rem; }
.s-speakers__quienes-item {
  display: flex; align-items: flex-start; gap: 8px;
  font-size: 0.88rem; color: rgba(35,35,35,0.78); line-height: 1.5;
}

/* Proceso 3 etapas */
.s-proceso { display: flex; flex-direction: column; gap: 0; margin-bottom: 2.5rem; position: relative; }
.s-proceso__step {
  display: flex; gap: 1rem; align-items: flex-start;
  padding-bottom: 1.5rem; position: relative;
}
.s-proceso__step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 18px;
  top: 36px;
  width: 2px;
  height: calc(100% - 20px);
  background: rgba(35,35,35,0.12);
}
.s-proceso__num {
  min-width: 36px; height: 36px;
  background: var(--color-ted-red);
  color: #fff;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem; font-weight: 700;
  flex-shrink: 0;
}
.s-proceso__content { padding-top: 4px; }
.s-proceso__title { font-size: 0.9rem; color: var(--color-charcoal); margin: 0 0 0.25rem; }
.s-proceso__desc { font-size: 0.82rem; color: rgba(35,35,35,0.65); line-height: 1.5; margin: 0; }

/* Form speaker */
.s-speakers__form-title { font-size: 1.2rem; color: var(--color-charcoal); margin-bottom: 0.25rem; }
.s-speakers__form-sub { font-size: 0.88rem; color: rgba(35,35,35,0.6); margin-bottom: 1.25rem; }

.form-speaker { display: flex; flex-direction: column; gap: 1rem; }
.form-speaker__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-speaker__field { display: flex; flex-direction: column; gap: 0.35rem; }

/* form-input ya está en global.css (dark) — sobreescribir para claro */
.s-speakers .form-input {
  background: #fff;
  border: 1.5px solid rgba(35,35,35,0.2);
  color: var(--color-charcoal);
}
.s-speakers .form-input::placeholder { color: rgba(35,35,35,0.4); }
.s-speakers .form-input:focus-visible {
  outline: 2px solid var(--color-ted-red);
  border-color: var(--color-ted-red);
}
.s-speakers .form-label { color: var(--color-charcoal); }

/* ── S10 PARTNERS ────────────────────────────────────────── */
.s-partners { padding: var(--spacing-section) 0; }
.s-partners__header { text-align: center; margin-bottom: 2.5rem; }
.s-partners__h2 { font-size: clamp(2rem, 5vw, 3.5rem); color: var(--color-charcoal); margin: 0.5rem 0 0.5rem; }
.s-partners__sub { color: rgba(35,35,35,0.65); font-size: 0.95rem; margin-bottom: 0.5rem; }
.s-partners__desc {
  font-size: 0.88rem; color: rgba(35,35,35,0.65); line-height: 1.65; max-width: 680px; margin: 0 auto;
}

.partners-carousel {
  display: flex; align-items: center; gap: 0.5rem;
  margin-bottom: 1.5rem;
}
.partners-track-wrap {
  flex: 1;
  overflow: hidden;
  border: 1.5px solid rgba(35,35,35,0.1);
  border-radius: 4px;
  min-height: 200px;
}
.partners-track {
  display: flex;
  transition: transform 0.35s ease;
}
.partners-slide {
  flex: 0 0 100%;          /* móvil: 1 visible */
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  min-height: 180px;
  border-right: 1px solid rgba(35,35,35,0.08);
}
.partners-slide__cat { text-align: center; color: var(--color-charcoal); }
.partners-slide__logos { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
.partners-logo { height: 60px; width: auto; object-fit: contain; }
.partners-placeholder {
  display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  border: 1.5px dashed rgba(35,35,35,0.2);
  border-radius: 4px;
  padding: 1.5rem 2.5rem;
  text-align: center;
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: rgba(35,35,35,0.65); /* era 0.45 (~2.8:1 falla) → 0.65 (~4.8:1 ✓ WCAG AA) */
}

.partners-prev,
.partners-next {
  background: var(--color-charcoal);
  color: #fff;
  border: none;
  border-radius: 4px;
  width: 38px; height: 38px;
  font-size: 1.4rem; line-height: 1;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
  flex-shrink: 0;
}
.partners-prev:hover,
.partners-next:hover { background: var(--color-ted-red); }
.partners-prev:focus-visible,
.partners-next:focus-visible { outline: 2px solid var(--color-ted-red); outline-offset: 2px; }

.partners-dots {
  display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 1.5rem;
}
.partners-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(35,35,35,0.2);
  border: none; padding: 0; cursor: pointer;
  transition: background 0.15s;
}
.partners-dot--active,
.partners-dot:hover { background: var(--color-ted-red); }

.s-partners__cta-text { text-align: center; font-size: 0.9rem; color: rgba(35,35,35,0.7); }
.s-partners__link {
  font-family: var(--font-display); font-weight: 700; text-decoration: none;
  letter-spacing: 0.04em;
}
.s-partners__link:hover { text-decoration: underline; }

/* ── S11 CONTACTO ─────────────────────────────────────────── */
.s-contacto { padding: var(--spacing-section) 0; background: var(--color-charcoal); }
.s-contacto__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}
.s-contacto__h2 {
  font-size: clamp(2.5rem, 6vw, 5rem);
  color: #ffffff;
  margin: 0.25rem 0 0.5rem;
}
.s-contacto__subtitulo {
  color: rgba(255,255,255,0.72);
